MDOP_MYSQL_IMAGE=mysql:8.4.10
MDOP_MYSQL_CONTAINER_NAME=mdop-mysql
MDOP_MYSQL_PORT=3306
MDOP_MYSQL_DATABASE=mdop
MDOP_MYSQL_USER=mdop_app
MDOP_MYSQL_PASSWORD=replace_with_local_password
MDOP_MYSQL_ROOT_PASSWORD=replace_with_local_root_password

MDOP_RABBITMQ_IMAGE=rabbitmq:4.3.2-management
MDOP_RABBITMQ_CONTAINER_NAME=mdop-rabbitmq
MDOP_RABBITMQ_HOSTNAME=mdop-rabbitmq
MDOP_RABBITMQ_AMQP_PORT=5672
MDOP_RABBITMQ_MANAGEMENT_PORT=15672
MDOP_RABBITMQ_USER=mdop_app
MDOP_RABBITMQ_PASSWORD=replace_with_local_password
MDOP_RABBITMQ_VHOST=mdop

MDOP_REDIS_IMAGE=redis:8.2.7
MDOP_REDIS_CONTAINER_NAME=mdop-redis
MDOP_REDIS_PORT=6379
MDOP_REDIS_PASSWORD=replace_with_local_password

MDOP_TIME_ZONE=Asia/Shanghai
